# Environment Variables — Trading Bot
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to GitHub or any public repository.
# Set these as environment variables in Claude Code AND Railway.

# ─── Alpaca ───────────────────────────────────────────────
# Get these from: https://app.alpaca.markets → API Keys
# Use PAPER keys until you switch TRADING_MODE to LIVE in config/guardrails.md

ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here

# ─── Tavily (free web search — 1,000/month free) ──────────
# Sign up at: https://tavily.com → Dashboard → API Keys
# No credit card needed for the free tier

TAVILY_API_KEY=your_tavily_api_key_here

# ─── Discord Bot ──────────────────────────────────────────
# BOT_TOKEN:  Discord Developer Portal → Your App → Bot → Token
# GUILD_ID:   Right-click your Discord server → Copy Server ID
# USER_ID:    Right-click your own profile in Discord → Copy User ID
# Enable Developer Mode in Discord: Settings → Advanced → Developer Mode

DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_USER_ID=your_personal_discord_user_id_here
