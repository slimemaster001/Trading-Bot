# ─────────────────────────────────────────────────────────────
#  TRADING BOT — Environment Variables Template
#  1. Copy this file:  copy .env.example .env
#  2. Fill in your real values below
#  3. The .env file is loaded automatically every time you run the bot
#  NEVER commit .env to GitHub (it's in .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Alpaca (REQUIRED) ─────────────────────────────────────────
# Get paper keys at: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama (optional — auto-detected if not set) ──────────────
# Only set OLLAMA_MODEL if you want to force a specific model
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Discord notifications (optional) ─────────────────────────
# Set these if you want trade alerts sent to your Discord DMs
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_GUILD_ID=your_discord_server_id_here
# DISCORD_USER_ID=your_personal_discord_user_id_here
